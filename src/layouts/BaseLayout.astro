---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A minimalist personal site and logs feed." } = Astro.props;

// We parse pathname to determine active navigation styling
const pathname = new URL(Astro.request.url).pathname;
const activeTab = (path: string) => {
  if (path === '/') {
    return pathname === '/' ? 'text-stone-900 dark:text-stone-50 border-b border-stone-900 dark:border-stone-50 font-bold' : 'text-stone-500 hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-50';
  }
  return pathname.startsWith(path) ? 'text-stone-900 dark:text-stone-50 border-b border-stone-900 dark:border-stone-50 font-bold' : 'text-stone-500 hover:text-stone-900 dark:text-stone-400 dark:hover:text-stone-50';
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Embedded SVG favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🌱</text></svg>" />
  </head>
  <body class="bg-stone-50 text-stone-900 dark:bg-stone-950 dark:text-stone-100 flex flex-col min-h-screen">
    <header class="border-b border-stone-200 dark:border-stone-900 py-6 sticky top-0 bg-stone-50/85 dark:bg-stone-950/85 backdrop-blur-md z-50">
      <div class="max-w-2xl mx-auto px-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <a href="/" class="font-mono text-lg font-bold tracking-tight hover:opacity-80 transition-opacity flex items-center gap-2">
          <span>vivekfyi</span>
        </a>
        <nav class="flex items-center gap-4 sm:gap-6 font-mono text-sm">
          <a href="/" class={`${activeTab('/')} py-1 transition-all`}>Home</a>
          <a href="/now" class={`${activeTab('/now')} py-1 transition-all`}>Now</a>
          <a href="/logs" class={`${activeTab('/logs')} py-1 transition-all`}>Logs</a>
          <a href="/uses" class={`${activeTab('/uses')} py-1 transition-all`}>Uses</a>
          <a href="/media" class={`${activeTab('/media')} py-1 transition-all`}>Media</a>
        </nav>
      </div>
    </header>

    <main class="flex-grow max-w-2xl mx-auto w-full px-4 py-12">
      <slot />
    </main>

    <footer class="border-t border-stone-200 dark:border-stone-900 py-8 font-mono text-xs text-stone-500 dark:text-stone-500 mt-auto">
      <div class="max-w-2xl mx-auto px-4 flex flex-col sm:flex-row justify-between gap-4">
        <p>&copy; {new Date().getFullYear()} — Built statically with Astro & Tailwind</p>
        <div class="flex gap-4">
          <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="hover:text-stone-900 dark:hover:text-stone-100 transition-colors">GitHub</a>
          <span class="text-stone-300 dark:text-stone-800">/</span>
          <a href="/rss.xml" class="hover:text-stone-900 dark:hover:text-stone-100 transition-colors">RSS</a>
        </div>
      </div>
    </footer>
  </body>
</html>
