---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

// Fetch the 'uses' JSON list
const usesEntry = await getEntry('lists', 'uses');
const items = usesEntry?.data?.items || [];

// Dynamically group items by category
const categories = [...new Set(items.map((item: any) => item.category))];
---

<BaseLayout title="~/uses — workspace & stack" description="A detailed log of my physical gear and digital configuration.">
  <div class="space-y-10">
    {/* Page Header */}
    <div class="space-y-3">
      <h1 class="text-3xl font-mono font-bold tracking-tight">/uses</h1>
      <p class="text-lg font-serif text-stone-600 dark:text-stone-400">
        A dynamic, flat-file catalog of physical hardware, software integrations, and daily tools that power my workflow.
      </p>
    </div>

    <hr class="border-stone-200 dark:border-stone-900" />

    {/* Categorized Lists */}
    <div class="space-y-12">
      {categories.length === 0 ? (
        <p class="font-serif text-stone-500 italic">No equipment listed.</p>
      ) : (
        categories.map(category => (
          <section class="space-y-4">
            <h2 class="text-xs font-mono font-bold uppercase tracking-wider text-stone-400 dark:text-stone-500 border-b border-stone-100 dark:border-stone-900 pb-1">
              {category}
            </h2>
            <ul class="space-y-6">
              {items
                .filter((item: any) => item.category === category)
                .map((item: any) => (
                  <li class="space-y-1">
                    <div class="flex items-baseline gap-1.5 flex-wrap">
                      {item.url ? (
                        <a
                          href={item.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="font-serif font-bold text-lg text-stone-900 hover:underline dark:text-stone-100 flex items-center gap-0.5"
                        >
                          {item.name}
                          <span class="text-xs text-stone-400 dark:text-stone-600 font-mono select-none">&nearr;</span>
                        </a>
                      ) : (
                        <span class="font-serif font-bold text-lg text-stone-900 dark:text-stone-100">
                          {item.name}
                        </span>
                      )}
                    </div>
                    <p class="font-serif text-stone-600 dark:text-stone-400 text-sm leading-relaxed">
                      {item.description}
                    </p>
                  </li>
                ))}
            </ul>
          </section>
        ))
      )}
    </div>
  </div>
</BaseLayout>
